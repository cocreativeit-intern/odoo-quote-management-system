<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form_msp_service" model="ir.ui.view">
        <field name="name">project.task.form.msp.service</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="MSP">
                    <group string="SLA">
                        <field name="x_msp_response_deadline"/>
                        <field name="x_msp_resolution_deadline"/>
                        <field name="x_msp_billing_state"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
