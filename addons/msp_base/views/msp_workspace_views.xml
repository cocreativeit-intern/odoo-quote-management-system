<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_msp_workspace_tree" model="ir.ui.view">
        <field name="name">msp.workspace.tree</field>
        <field name="model">msp.workspace</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_msp_workspace_form" model="ir.ui.view">
        <field name="name">msp.workspace.form</field>
        <field name="model">msp.workspace</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_msp_workspace" model="ir.actions.act_window">
        <field name="name">MSP Workspaces</field>
        <field name="res_model">msp.workspace</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_msp_root" name="MSP"/>
    <menuitem id="menu_msp_workspace" name="Workspaces" parent="menu_msp_root" action="action_msp_workspace"/>
</odoo>
