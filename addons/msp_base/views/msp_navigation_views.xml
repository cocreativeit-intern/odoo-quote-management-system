<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_msp_products" model="ir.actions.act_window">
        <field name="name">Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_msp_quotes" model="ir.actions.act_window">
        <field name="name">Quotes</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['draft', 'sent', 'tech_review', 'finance_review'])]</field>
    </record>

    <record id="action_msp_sales" model="ir.actions.act_window">
        <field name="name">Sales</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['sale', 'done'])]</field>
    </record>

    <record id="action_msp_purchases" model="ir.actions.act_window">
        <field name="name">Purchases</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_msp_organizations" model="ir.actions.act_window">
        <field name="name">Organizations</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_company', '=', True), ('customer_rank', '>', 0)]</field>
    </record>

    <record id="action_msp_service_tasks" model="ir.actions.act_window">
        <field name="name">Service Tasks</field>
        <field name="res_model">project.task</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="action_msp_reports" model="ir.actions.act_window">
        <field name="name">Reports</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">pivot,graph,list</field>
        <field name="domain">[('state', 'in', ['sale', 'done'])]</field>
    </record>

    <menuitem id="menu_msp_dashboard" name="Dashboard" parent="msp_base.menu_msp_root" action="action_msp_dashboard" sequence="5"/>
    <menuitem id="menu_msp_products" name="Products" parent="msp_base.menu_msp_root" action="action_msp_products" sequence="10"/>
    <menuitem id="menu_msp_quotes" name="Quotes" parent="msp_base.menu_msp_root" action="action_msp_quotes" sequence="20"/>
    <menuitem id="menu_msp_sales" name="Sales" parent="msp_base.menu_msp_root" action="action_msp_sales" sequence="30"/>
    <menuitem id="menu_msp_purchases" name="Purchases" parent="msp_base.menu_msp_root" action="action_msp_purchases" sequence="40"/>
    <menuitem id="menu_msp_organizations" name="Organizations" parent="msp_base.menu_msp_root" action="action_msp_organizations" sequence="50"/>
    <menuitem id="menu_msp_service" name="Service" parent="msp_base.menu_msp_root" action="action_msp_service_tasks" sequence="60"/>
    <menuitem id="menu_msp_reports" name="Reports" parent="msp_base.menu_msp_root" action="action_msp_reports" sequence="70"/>
</odoo>
