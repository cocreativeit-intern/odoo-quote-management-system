<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="purchase_order_form_msp_procurement" model="ir.ui.view">
        <field name="name">purchase.order.form.msp.procurement</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="MSP">
                    <group string="Order Linkage">
                        <field name="x_msp_source_sale_order_id"/>
                        <field name="x_msp_delivery_readiness"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
